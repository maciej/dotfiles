#!/usr/bin/env python3

from __future__ import annotations

import argparse
import difflib
import json
import os
import sys
import tempfile
from pathlib import Path
from typing import Any

LOCAL_ONLY_KEYS = {"ssh_connections", "telemetry"}
EXIT_DIFF = 1
EXIT_CONFLICT = 2


class ConfigError(Exception):
    pass


class ConflictError(ConfigError):
    pass


def strip_json_comments(text: str) -> str:
    result: list[str] = []
    in_string = False
    escape = False
    in_line_comment = False
    in_block_comment = False
    index = 0

    while index < len(text):
        char = text[index]
        next_char = text[index + 1] if index + 1 < len(text) else ""

        if in_line_comment:
            if char == "\n":
                in_line_comment = False
                result.append(char)
            index += 1
            continue

        if in_block_comment:
            if char == "*" and next_char == "/":
                in_block_comment = False
                index += 2
            else:
                index += 1
            continue

        if in_string:
            result.append(char)
            if escape:
                escape = False
            elif char == "\\":
                escape = True
            elif char == '"':
                in_string = False
            index += 1
            continue

        if char == '"':
            in_string = True
            result.append(char)
            index += 1
            continue

        if char == "/" and next_char == "/":
            in_line_comment = True
            index += 2
            continue

        if char == "/" and next_char == "*":
            in_block_comment = True
            index += 2
            continue

        result.append(char)
        index += 1

    if in_block_comment or in_string:
        raise ConfigError("invalid JSONC input")

    return "".join(result)


def strip_trailing_commas(text: str) -> str:
    result: list[str] = []
    in_string = False
    escape = False
    index = 0

    while index < len(text):
        char = text[index]

        if in_string:
            result.append(char)
            if escape:
                escape = False
            elif char == "\\":
                escape = True
            elif char == '"':
                in_string = False
            index += 1
            continue

        if char == '"':
            in_string = True
            result.append(char)
            index += 1
            continue

        if char == ",":
            next_index = index + 1
            while next_index < len(text) and text[next_index].isspace():
                next_index += 1
            if next_index < len(text) and text[next_index] in "]}":
                index += 1
                continue

        result.append(char)
        index += 1

    if in_string:
        raise ConfigError("invalid JSONC input")

    return "".join(result)


def load_json(path: Path, *, allow_comments: bool) -> dict[str, Any]:
    try:
        text = path.read_text(encoding="utf-8")
    except FileNotFoundError as exc:
        raise ConfigError(f"missing file: {path}") from exc

    if allow_comments:
        text = strip_json_comments(text)
        text = strip_trailing_commas(text)

    try:
        data = json.loads(text)
    except json.JSONDecodeError as exc:
        raise ConfigError(f"failed to parse JSON in {path}: {exc}") from exc

    if not isinstance(data, dict):
        raise ConfigError(f"expected top-level object in {path}")

    return data


def write_json_atomic(path: Path, data: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile(
        "w", encoding="utf-8", dir=path.parent, delete=False
    ) as handle:
        json.dump(data, handle, indent=2)
        handle.write("\n")
        temp_name = handle.name
    os.replace(temp_name, path)


def canonical_json(data: dict[str, Any]) -> str:
    return json.dumps(data, indent=2, sort_keys=True) + "\n"


def load_optional_json(path: Path, *, allow_comments: bool) -> dict[str, Any] | None:
    if not path.exists():
        return None
    return load_json(path, allow_comments=allow_comments)


def diff_label(path: Path, *, exists: bool, suffix: str) -> str:
    if not exists:
        return "/dev/null"
    return f"{path} ({suffix})"


def json_diff(
    before: dict[str, Any] | None,
    after: dict[str, Any] | None,
    *,
    path: Path,
) -> str:
    before_lines = canonical_json(before).splitlines(keepends=True) if before is not None else []
    after_lines = canonical_json(after).splitlines(keepends=True) if after is not None else []
    return "".join(
        difflib.unified_diff(
            before_lines,
            after_lines,
            fromfile=diff_label(path, exists=before is not None, suffix="current"),
            tofile=diff_label(path, exists=after is not None, suffix="new"),
        )
    )


def print_diff(title: str, diff_text: str) -> None:
    print(f"{title}:")
    print(diff_text, end="")


def default_paths(repo_root: Path) -> tuple[Path, Path, Path]:
    xdg_config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    zed_dir = xdg_config_home / "zed"
    return (
        repo_root / ".config" / "zed" / "settings.json",
        zed_dir / "settings.local.json",
        zed_dir / "settings.json",
    )


def resolve_paths(args: argparse.Namespace) -> tuple[Path, Path, Path]:
    repo_root = Path(args.repo_root).expanduser().resolve()
    shared_default, local_default, live_default = default_paths(repo_root)
    shared = Path(args.shared or shared_default).expanduser()
    local = Path(args.local or local_default).expanduser()
    live = Path(args.live or live_default).expanduser()
    return shared, local, live


def validate_shared(data: dict[str, Any], path: Path) -> None:
    unexpected = sorted(LOCAL_ONLY_KEYS.intersection(data))
    if unexpected:
        keys = ", ".join(unexpected)
        raise ConfigError(f"{path} must not contain local-only keys: {keys}")


def validate_local(data: dict[str, Any], path: Path) -> None:
    unexpected = sorted(set(data) - LOCAL_ONLY_KEYS)
    if unexpected:
        keys = ", ".join(unexpected)
        raise ConfigError(f"{path} contains unsupported top-level keys: {keys}")


def live_is_newer_than_sources(
    live_path: Path, source_paths: list[Path], *, force: bool
) -> None:
    if force or not live_path.exists():
        return

    live_mtime = live_path.stat().st_mtime_ns
    source_mtimes = [path.stat().st_mtime_ns for path in source_paths if path.exists()]
    if not source_mtimes:
        return

    if live_mtime > max(source_mtimes):
        raise ConflictError(
            f"refusing to overwrite newer live settings at {live_path}; "
            "run `./scripts/zed-settings pull` first or use `push --force` "
            "to make dotfiles win"
        )


def source_is_older_than_targets(
    source_path: Path, target_paths: list[Path], *, force: bool
) -> None:
    if force or not source_path.exists():
        return

    source_mtime = source_path.stat().st_mtime_ns
    newer_targets = [path for path in target_paths if path.exists() and path.stat().st_mtime_ns > source_mtime]
    if not newer_targets:
        return

    target_list = ", ".join(str(path) for path in newer_targets)
    raise ConflictError(
        f"refusing to overwrite newer repo/local settings at {target_list} "
        f"with {source_path}; use `pull --force` to make the live file win"
    )


def local_payload_from_live(data: dict[str, Any]) -> dict[str, Any]:
    payload: dict[str, Any] = {}
    ssh_connections = data.get("ssh_connections")
    if ssh_connections:
        payload["ssh_connections"] = ssh_connections
    telemetry = data.get("telemetry")
    if telemetry:
        payload["telemetry"] = telemetry
    return payload


def shared_payload(data: dict[str, Any]) -> dict[str, Any]:
    return {key: value for key, value in data.items() if key not in LOCAL_ONLY_KEYS}


def load_repo_settings(shared_path: Path, local_path: Path) -> dict[str, Any]:
    shared = load_json(shared_path, allow_comments=False)
    validate_shared(shared, shared_path)

    merged = dict(shared)
    if local_path.exists():
        local = load_json(local_path, allow_comments=False)
        validate_local(local, local_path)
        merged.update(local)

    return merged


def pull(
    shared_path: Path,
    local_path: Path,
    live_path: Path,
    *,
    force: bool,
    quiet: bool,
) -> None:
    live = load_json(live_path, allow_comments=True)
    shared = shared_payload(live)
    local = local_payload_from_live(live)
    shared_diff = json_diff(
        load_optional_json(shared_path, allow_comments=False),
        shared,
        path=shared_path,
    )
    local_diff = json_diff(
        load_optional_json(local_path, allow_comments=False),
        local or None,
        path=local_path,
    )

    if not quiet:
        if shared_diff:
            print_diff(f"Pulling shared diff into dotfiles at {shared_path}", shared_diff)
        if local_diff:
            print_diff(f"Pulling local-only diff into {local_path}", local_diff)
        if not shared_diff and not local_diff:
            print("Dotfiles and local-only Zed settings already match the live configuration.")

    if not shared_diff and not local_diff:
        return

    source_is_older_than_targets(live_path, [shared_path, local_path], force=force)

    write_json_atomic(shared_path, shared)
    if local:
        write_json_atomic(local_path, local)
    elif local_path.exists():
        local_path.unlink()


def push(
    shared_path: Path,
    local_path: Path,
    live_path: Path,
    *,
    force: bool,
    quiet: bool,
) -> None:
    merged = load_repo_settings(shared_path, local_path)
    live_diff = json_diff(
        load_optional_json(live_path, allow_comments=True),
        merged,
        path=live_path,
    )

    if not quiet:
        if live_diff:
            print_diff(
                f"Pushing diff to system configuration at {live_path}",
                live_diff,
            )
        else:
            print("System configuration already matches the repo and local Zed settings.")

    if not live_diff:
        return

    live_is_newer_than_sources(live_path, [shared_path, local_path], force=force)

    write_json_atomic(live_path, merged)


def diff(shared_path: Path, local_path: Path, live_path: Path) -> bool:
    repo = shared_payload(load_repo_settings(shared_path, local_path))
    live = shared_payload(load_json(live_path, allow_comments=True))
    repo_label = str(shared_path)

    repo_json = canonical_json(repo).splitlines(keepends=True)
    live_json = canonical_json(live).splitlines(keepends=True)
    diff_lines = list(
        difflib.unified_diff(
            repo_json,
            live_json,
            fromfile=repo_label,
            tofile=str(live_path),
        )
    )

    if not diff_lines:
        return False

    print("".join(diff_lines), end="")
    return True


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Split and merge shared/local Zed settings."
    )
    parser.add_argument(
        "--repo-root",
        default=Path(__file__).resolve().parent.parent,
        help="Dotfiles repository root. Defaults to the parent of this script.",
    )
    parser.add_argument("--shared", help="Path to the tracked shared settings file.")
    parser.add_argument("--local", help="Path to the local-only settings file.")
    parser.add_argument("--live", help="Path to the live Zed settings file.")

    subparsers = parser.add_subparsers(dest="command", required=True)
    pull_parser = subparsers.add_parser(
        "pull", help="Split the live settings into shared and local files."
    )
    pull_parser.add_argument(
        "--force",
        action="store_true",
        help="Overwrite the shared/local files even if they are newer than the live settings.",
    )
    pull_parser.add_argument(
        "--quiet",
        action="store_true",
        help="Suppress the default diff output before writing files.",
    )
    push_parser = subparsers.add_parser(
        "push", help="Merge the shared and local files into the live settings."
    )
    push_parser.add_argument(
        "--force",
        action="store_true",
        help="Overwrite the live settings even if they are newer than the repo inputs.",
    )
    push_parser.add_argument(
        "--quiet",
        action="store_true",
        help="Suppress the default diff output before writing files.",
    )
    subparsers.add_parser(
        "diff",
        help="Show a JSON-aware diff between the repo settings and the live settings.",
    )
    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    shared_path, local_path, live_path = resolve_paths(args)

    try:
        if args.command == "pull":
            pull(shared_path, local_path, live_path, force=args.force, quiet=args.quiet)
        elif args.command == "push":
            push(shared_path, local_path, live_path, force=args.force, quiet=args.quiet)
        elif args.command == "diff":
            return EXIT_DIFF if diff(shared_path, local_path, live_path) else 0
        else:
            raise ConfigError(f"unsupported command: {args.command}")
    except ConflictError as exc:
        print(f"zed-settings: {exc}", file=sys.stderr)
        return EXIT_CONFLICT
    except ConfigError as exc:
        print(f"zed-settings: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
