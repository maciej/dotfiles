#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# shellcheck source=../install.sh
source "${ROOT_DIR}/install.sh"

assert_file_equals() {
  local file="$1"
  local expected="$2"
  local actual

  actual="$(cat "${file}")"
  if [[ "${actual}" != "${expected}" ]]; then
    printf "Expected %s to contain:\n%s\n\nActual:\n%s\n" "${file}" "${expected}" "${actual}" >&2
    return 1
  fi
}

with_temp_home() {
  local test_name="$1"
  shift

  local temp_home
  temp_home="$(mktemp -d)"
  trap 'rm -rf "${temp_home}"' RETURN
  HOME="${temp_home}" XDG_CONFIG_HOME= SSH_CONFIG_INCLUDE_PATTERN="${temp_home}/.ssh/config.d/*.conf" "$@"
  rm -rf "${temp_home}"
  trap - RETURN
  printf "ok - %s\n" "${test_name}"
}

reset_local_install_state() {
  LOCAL_INSTALL=false
  LOCAL_INSTALL_CHOICE=auto
}

test_creates_missing_config() {
  local old_umask

  old_umask="$(umask)"
  ensure_ssh_config_fragment_directory
  ensure_ssh_config_include

  assert_file_equals "${HOME}/.ssh/config" "Include ${SSH_CONFIG_INCLUDE_PATTERN}"
  [[ "$(umask)" == "${old_umask}" ]]
}

test_inserts_before_first_host() {
  ensure_ssh_config_fragment_directory
  cat >"${HOME}/.ssh/config" <<'EOF'
CanonicalizeHostname yes

Host example
  User local
EOF

  ensure_ssh_config_include

  assert_file_equals "${HOME}/.ssh/config" "CanonicalizeHostname yes

Include ${SSH_CONFIG_INCLUDE_PATTERN}
Host example
  User local"
}

test_appends_without_host_blocks() {
  ensure_ssh_config_fragment_directory
  cat >"${HOME}/.ssh/config" <<'EOF'
CanonicalizeHostname yes
HashKnownHosts yes
EOF

  ensure_ssh_config_include

  assert_file_equals "${HOME}/.ssh/config" "CanonicalizeHostname yes
HashKnownHosts yes
Include ${SSH_CONFIG_INCLUDE_PATTERN}"
}

test_is_idempotent() {
  ensure_ssh_config_fragment_directory
  printf "Include %s\n" "${SSH_CONFIG_INCLUDE_PATTERN}" >"${HOME}/.ssh/config"

  ensure_ssh_config_include
  ensure_ssh_config_include

  assert_file_equals "${HOME}/.ssh/config" "Include ${SSH_CONFIG_INCLUDE_PATTERN}"
}

test_ssh_reads_included_fragment() {
  command -v ssh >/dev/null 2>&1 || {
    printf "skip - ssh is unavailable\n"
    return
  }

  ensure_ssh_config_fragment_directory
  cat >"${HOME}/.ssh/config.d/git-maciejb-me.conf" <<'EOF'
Host git.maciejb.me
  User git
  Port 2222
EOF
  cat >"${HOME}/.ssh/config" <<'EOF'
Host *
  User fallback
EOF

  ensure_ssh_config_include

  local rendered
  rendered="$(ssh -F "${HOME}/.ssh/config" -G git.maciejb.me 2>/dev/null)"
  grep -qx "user git" <<<"${rendered}"
  grep -qx "port 2222" <<<"${rendered}"
}

test_local_install_marker_uses_xdg_config_home() {
  reset_local_install_state
  XDG_CONFIG_HOME="${HOME}/xdg-config"

  [[ "$(local_install_marker_path)" == "${HOME}/xdg-config/dotfiles/install-mode" ]]
}

test_local_install_marker_defaults_to_home_config() {
  reset_local_install_state
  unset XDG_CONFIG_HOME

  [[ "$(local_install_marker_path)" == "${HOME}/.config/dotfiles/install-mode" ]]
}

test_local_install_marker_enables_local_default() {
  local marker
  reset_local_install_state
  marker="$(local_install_marker_path)"
  mkdir -p "$(dirname "${marker}")"
  printf "local\n" >"${marker}"

  parse_args
  apply_local_install_default

  [[ "${LOCAL_INSTALL}" == "true" ]]
}

test_explicit_local_writes_marker() {
  local marker
  reset_local_install_state
  marker="$(local_install_marker_path)"

  parse_args --local
  apply_local_install_default
  update_local_install_default_marker

  [[ "${LOCAL_INSTALL}" == "true" ]]
  assert_file_equals "${marker}" "local"
}

test_no_local_clears_marker() {
  local marker
  reset_local_install_state
  marker="$(local_install_marker_path)"
  mkdir -p "$(dirname "${marker}")"
  printf "local\n" >"${marker}"

  parse_args --no-local
  apply_local_install_default
  update_local_install_default_marker

  [[ "${LOCAL_INSTALL}" == "false" ]]
  [[ ! -e "${marker}" ]]
}

test_codex_local_installer_uses_home_scoped_env() {
  local capture fake_bin

  UPGRADE=false
  fake_bin="${HOME}/fake-bin"
  capture="${HOME}/codex-env"
  mkdir -p "${fake_bin}"

  cat >"${fake_bin}/curl" <<'EOF'
#!/usr/bin/env bash
printf '# fake Codex installer\n'
EOF
  chmod 755 "${fake_bin}/curl"

  cat >"${fake_bin}/sh" <<'EOF'
#!/usr/bin/env bash
while IFS= read -r _line; do
  :
done
{
  printf 'CODEX_INSTALL_DIR=%s\n' "${CODEX_INSTALL_DIR:-}"
  printf 'CODEX_HOME=%s\n' "${CODEX_HOME:-}"
  printf 'CODEX_NON_INTERACTIVE=%s\n' "${CODEX_NON_INTERACTIVE:-}"
} >"${CODEX_TEST_ENV_CAPTURE:?}"
EOF
  chmod 755 "${fake_bin}/sh"

  PATH="${fake_bin}:${PATH}" CODEX_TEST_ENV_CAPTURE="${capture}" install_codex_cli_local

  assert_file_equals "${capture}" "CODEX_INSTALL_DIR=${HOME}/.local/bin
CODEX_HOME=${HOME}/.codex
CODEX_NON_INTERACTIVE=1"
}

test_local_release_installers_install_bat_and_delta() {
  local fake_bin

  UPGRADE=false
  fake_bin="${HOME}/fake-bin"
  mkdir -p "${fake_bin}"

  cat >"${fake_bin}/curl" <<'EOF'
#!/usr/bin/env bash
output_file=""
url=""
while (( $# > 0 )); do
  case "$1" in
    -o)
      output_file="$2"
      shift 2
      ;;
    -*)
      shift
      ;;
    *)
      url="$1"
      shift
      ;;
  esac
done

case "${url}" in
  https://api.github.com/repos/sharkdp/bat/releases/latest)
    printf '{"assets":[{"name":"bat-v0.0.0-x86_64-unknown-linux-gnu.tar.gz","browser_download_url":"https://example.test/bat-v0.0.0-x86_64-unknown-linux-gnu.tar.gz","size":1024}]}'
    ;;
  https://api.github.com/repos/dandavison/delta/releases/latest)
    printf '{"assets":[{"name":"delta-0.0.0-x86_64-unknown-linux-gnu.tar.gz","browser_download_url":"https://example.test/delta-0.0.0-x86_64-unknown-linux-gnu.tar.gz","size":1024}]}'
    ;;
  https://example.test/*)
    printf 'fake archive' >"${output_file:?}"
    ;;
  *)
    printf 'unexpected curl URL: %s\n' "${url}" >&2
    exit 1
    ;;
esac
EOF
  chmod 755 "${fake_bin}/curl"

  cat >"${fake_bin}/tar" <<'EOF'
#!/usr/bin/env bash
archive=""
dest=""
while (( $# > 0 )); do
  case "$1" in
    -C)
      dest="$2"
      shift 2
      ;;
    -*)
      shift
      ;;
    *)
      archive="$1"
      shift
      ;;
  esac
done

case "${archive}" in
  *bat*)
    mkdir -p "${dest:?}/bat-release"
    printf 'bat binary' >"${dest}/bat-release/bat"
    chmod 700 "${dest}/bat-release/bat"
    ;;
  *delta*)
    mkdir -p "${dest:?}/delta-release"
    printf 'delta binary' >"${dest}/delta-release/delta"
    chmod 700 "${dest}/delta-release/delta"
    ;;
  *)
    printf 'unexpected archive: %s\n' "${archive}" >&2
    exit 1
    ;;
esac
EOF
  chmod 755 "${fake_bin}/tar"

  cat >"${fake_bin}/uname" <<'EOF'
#!/usr/bin/env bash
case "${1:-}" in
  -s)
    printf 'Linux\n'
    ;;
  -m)
    printf 'x86_64\n'
    ;;
  *)
    printf 'Linux\n'
    ;;
esac
EOF
  chmod 755 "${fake_bin}/uname"

  PATH="${fake_bin}:${PATH}" install_bat_local
  PATH="${fake_bin}:${PATH}" install_git_delta_local

  [[ -x "${HOME}/.local/bin/bat" ]]
  [[ -x "${HOME}/.local/bin/delta" ]]
  assert_file_equals "${HOME}/.local/bin/bat" "bat binary"
  assert_file_equals "${HOME}/.local/bin/delta" "delta binary"
}

make_fake_apt_bin() {
  local fake_bin="$1"

  mkdir -p "${fake_bin}"

  cat >"${fake_bin}/sudo" <<'EOF'
#!/usr/bin/env bash
exec "$@"
EOF
  chmod 755 "${fake_bin}/sudo"

  cat >"${fake_bin}/apt-get" <<'EOF'
#!/usr/bin/env bash
printf 'apt-get %s\n' "$*" >>"${APT_TEST_LOG:?}"
EOF
  chmod 755 "${fake_bin}/apt-get"

  cat >"${fake_bin}/apt-cache" <<'EOF'
#!/usr/bin/env bash
if [[ "${1:-}" != "show" ]]; then
  printf 'unexpected apt-cache command: %s\n' "$*" >&2
  exit 1
fi

case " ${APT_TEST_AVAILABLE:-} " in
  *" ${2:-} "*)
    printf 'Package: %s\n' "$2"
    ;;
  *)
    exit 100
    ;;
esac
EOF
  chmod 755 "${fake_bin}/apt-cache"

  cat >"${fake_bin}/dpkg-query" <<'EOF'
#!/usr/bin/env bash
pkg="${@: -1}"
case " ${APT_TEST_INSTALLED:-} " in
  *" ${pkg} "*)
    printf 'install ok installed'
    ;;
  *)
    exit 1
    ;;
esac
EOF
  chmod 755 "${fake_bin}/dpkg-query"
}

test_apt_skips_unavailable_optional_packages() {
  local fake_bin log_file
  local APT_PACKAGES=(curl git)
  local APT_OPTIONAL_PACKAGES=(lazygit)

  fake_bin="${HOME}/fake-bin"
  log_file="${HOME}/apt.log"
  make_fake_apt_bin "${fake_bin}"

  PATH="${fake_bin}:${PATH}" \
    APT_TEST_LOG="${log_file}" \
    APT_TEST_AVAILABLE="curl git" \
    APT_TEST_INSTALLED="" \
    install_apt_packages

  assert_file_equals "${log_file}" "apt-get update
apt-get install -y curl git"
}

test_apt_fails_when_required_package_is_unavailable() {
  local fake_bin log_file output status
  local APT_PACKAGES=(curl missing-required)
  local APT_OPTIONAL_PACKAGES=(lazygit)

  fake_bin="${HOME}/fake-bin"
  log_file="${HOME}/apt.log"
  make_fake_apt_bin "${fake_bin}"

  output="$(
    PATH="${fake_bin}:${PATH}" \
      APT_TEST_LOG="${log_file}" \
      APT_TEST_AVAILABLE="curl" \
      APT_TEST_INSTALLED="" \
      install_apt_packages 2>&1
  )" && status=0 || status=$?

  [[ "${status}" -ne 0 ]]
  grep -q "Required apt package is unavailable in configured repositories: missing-required" <<<"${output}"
  assert_file_equals "${log_file}" "apt-get update"
}

test_make_rejects_unknown_install_target() {
  local output status

  output="$(make -C "${ROOT_DIR}" -n install 2>&1)" && status=0 || status=$?

  [[ "${status}" -ne 0 ]]
  grep -q "Unknown target(s): install" <<<"${output}"
}

with_temp_home "creates missing config" test_creates_missing_config
with_temp_home "inserts before first host" test_inserts_before_first_host
with_temp_home "appends without host blocks" test_appends_without_host_blocks
with_temp_home "is idempotent" test_is_idempotent
with_temp_home "ssh reads included fragment" test_ssh_reads_included_fragment
with_temp_home "local install marker uses XDG_CONFIG_HOME" test_local_install_marker_uses_xdg_config_home
with_temp_home "local install marker defaults to HOME config" test_local_install_marker_defaults_to_home_config
with_temp_home "local install marker enables local default" test_local_install_marker_enables_local_default
with_temp_home "explicit local writes marker" test_explicit_local_writes_marker
with_temp_home "no local clears marker" test_no_local_clears_marker
with_temp_home "Codex local installer uses home-scoped environment" test_codex_local_installer_uses_home_scoped_env
with_temp_home "local release installers install bat and delta" test_local_release_installers_install_bat_and_delta
with_temp_home "apt skips unavailable optional packages" test_apt_skips_unavailable_optional_packages
with_temp_home "apt fails when required package is unavailable" test_apt_fails_when_required_package_is_unavailable
with_temp_home "make rejects unknown install target" test_make_rejects_unknown_install_target
