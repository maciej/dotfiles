#!/bin/sh
set -eu

script=$0
while [ -L "$script" ]; do
    dir=$(CDPATH= cd "$(dirname "$script")" && pwd -P)
    target=$(readlink "$script")
    case $target in
        /*) script=$target ;;
        *) script=$dir/$target ;;
    esac
done

repo_root=$(CDPATH= cd "$(dirname "$script")/../.." && pwd -P)
toolbox=$repo_root/toolbox

export PYTHONPATH="${toolbox}/src${PYTHONPATH:+:${PYTHONPATH}}"
exec uv run --project "${toolbox}" --extra whisper python -m yt_summarize "$@"
